// PDA L = { a^n b^n | n >= 1 }
//
// Estados: q0, q1, q2 (aceita)
// Pilha: A (marcador), Z (fundo)
//
// q0, a, Z -> q0, AZ
// q0, a, A -> q0, AA
// q0, b, A -> q1, ""
// q1, b, A -> q1, ""
// q1, eps, Z -> q2, Z

#include <iostream>
#include <string>
#include <vector>
#include <stack>
#include <tuple>
#include <unordered_map>
#include <optional>
#include <sstream>

using namespace std;

struct Transicao {
    string proximoEstado;
    string empilhar; // vazio = nao empilha nada
};

struct ChaveHash {
    size_t operator()(const tuple<string, char, char>& k) const {
        auto [estado, simbolo, topo] = k;
        return hash<string>()(estado) ^ (hash<char>()(simbolo) << 8) ^ (hash<char>()(topo) << 16);
    }
};

struct Config {
    string estado;
    size_t pos;
    stack<char> pilha;
};

class PDA {
public:
    string estadoInicial;
    char simboloInicialPilha;
    vector<string> estadosAceitacao;
    unordered_map<tuple<string, char, char>, vector<Transicao>, ChaveHash> transicoes;

    void addTransicao(string de, char simbolo, char topo, string para, string empilhar) {
        transicoes[{de, simbolo, topo}].push_back({para, empilhar});
    }

    bool aceita(const string& entrada, bool mostrarPassos) {
        stack<char> pilhaInicial;
        pilhaInicial.push(simboloInicialPilha);

        vector<Config> agenda;
        agenda.push_back({estadoInicial, 0, pilhaInicial});

        if (mostrarPassos) cout << "\nProcessando \"" << entrada << "\"\n";

        while (!agenda.empty()) {
            Config atual = agenda.back();
            agenda.pop_back();

            if (mostrarPassos) imprimeConfig(atual.estado, atual.pos, atual.pilha, entrada);

            if (atual.pos == entrada.size() && ehAceitacao(atual.estado)) {
                if (mostrarPassos) cout << "-> ACEITO\n";
                return true;
            }

            if (atual.pilha.empty()) continue;
            char topo = atual.pilha.top();

            // transicao epsilon (nao consome entrada)
            auto chaveEps = make_tuple(atual.estado, '\0', topo);
            auto itEps = transicoes.find(chaveEps);
            if (itEps != transicoes.end()) {
                for (auto& t : itEps->second)
                    agenda.push_back(aplica(atual, t));
            }

            // transicao consumindo o proximo simbolo de entrada
            if (atual.pos < entrada.size()) {
                auto chave = make_tuple(atual.estado, entrada[atual.pos], topo);
                auto it = transicoes.find(chave);
                if (it != transicoes.end()) {
                    for (auto& t : it->second) {
                        Config nova = aplica(atual, t);
                        nova.pos++;
                        agenda.push_back(nova);
                    }
                }
            }
        }

        if (mostrarPassos) cout << "-> REJEITADO\n";
        return false;
    }

private:
    bool ehAceitacao(const string& estado) {
        for (auto& s : estadosAceitacao) if (s == estado) return true;
        return false;
    }

    // tira o topo da pilha e empilha os simbolos de t.empilhar (ultimo char = fundo)
    Config aplica(Config c, const Transicao& t) {
        c.estado = t.proximoEstado;
        c.pilha.pop();
        for (int i = (int)t.empilhar.size() - 1; i >= 0; i--)
            c.pilha.push(t.empilhar[i]);
        return c;
    }

    void imprimeConfig(const string& estado, size_t pos, stack<char> pilha, const string& entrada) {
        string resto = entrada.substr(pos);
        if (resto.empty()) resto = "eps";

        string pilhaStr;
        while (!pilha.empty()) { pilhaStr += pilha.top(); pilha.pop(); }
        if (pilhaStr.empty()) pilhaStr = "vazia";

        cout << "  (" << estado << ", " << resto << ", " << pilhaStr << ")\n";
    }
};

PDA criaPDApadrao() {
    PDA pda;
    pda.estadoInicial = "q0";
    pda.simboloInicialPilha = 'Z';
    pda.estadosAceitacao = {"q2"};

    pda.addTransicao("q0", 'a', 'Z', "q0", "AZ");
    pda.addTransicao("q0", 'a', 'A', "q0", "AA");
    pda.addTransicao("q0", 'b', 'A', "q1", "");
    pda.addTransicao("q1", 'b', 'A', "q1", "");
    pda.addTransicao("q1", '\0', 'Z', "q2", "Z");

    return pda;
}

// le uma transicao do tipo: q0 a Z q0 AZ
// "eps" = simbolo vazio, "-" = nao empilha nada
bool leTransicao(PDA& pda) {
    cout << "Transicao (de simbolo topo para empilhar), ou ENTER para terminar: ";
    string linha;
    getline(cin, linha);
    if (linha.empty()) return false;

    istringstream iss(linha);
    string de, simboloStr, topoStr, para, empilhar;
    iss >> de >> simboloStr >> topoStr >> para;
    if (!(iss >> empilhar)) empilhar = "-";

    char simbolo = (simboloStr == "eps") ? '\0' : simboloStr[0];
    char topo = topoStr[0];
    if (empilhar == "-") empilhar = "";

    pda.addTransicao(de, simbolo, topo, para, empilhar);
    return true;
}

PDA criaPDApersonalizado() {
    PDA pda;

    cout << "Estado inicial: ";
    getline(cin, pda.estadoInicial);

    cout << "Simbolo inicial da pilha: ";
    string s;
    getline(cin, s);
    pda.simboloInicialPilha = s[0];

    cout << "Estados de aceitacao (separados por espaco): ";
    string linha;
    getline(cin, linha);
    istringstream iss(linha);
    string estado;
    while (iss >> estado) pda.estadosAceitacao.push_back(estado);

    cout << "\nDigite as transicoes no formato: de simbolo topo para empilhar\n";
    cout << "ex: q0 a Z q0 AZ   (eps = simbolo vazio, - = nao empilha nada)\n\n";
    while (leTransicao(pda)) {}

    return pda;
}

void testaPalavra(PDA& pda) {
    cout << "Palavra: ";
    string palavra;
    getline(cin, palavra);
    bool resultado = pda.aceita(palavra, true);
    cout << (resultado ? "ACEITO" : "REJEITADO") << "\n";
}

void rodaTestes(PDA& pda) {
    vector<pair<string, bool>> testes = {
        {"ab", true}, {"aabb", true}, {"aaabbb", true},
        {"", false}, {"a", false}, {"b", false},
        {"ba", false}, {"aab", false}, {"abb", false}, {"abab", false},
    };

    int passou = 0;
    for (auto& [palavra, esperado] : testes) {
        bool resultado = pda.aceita(palavra, false);
        bool ok = (resultado == esperado);
        if (ok) passou++;
        cout << (palavra.empty() ? "eps" : palavra) << ": esperado="
             << (esperado ? "aceitar" : "rejeitar") << " resultado="
             << (resultado ? "aceitar" : "rejeitar") << (ok ? " ok" : " FALHOU") << "\n";
    }
    cout << passou << "/" << testes.size() << " testes passaram\n";
}

int main() {
    PDA pda = criaPDApadrao();

    while (true) {
        cout << "\n--- PDA: a^n b^n ---\n";
        cout << "1 - usar PDA padrao\n";
        cout << "2 - criar PDA personalizado\n";
        cout << "3 - testar uma palavra\n";
        cout << "4 - rodar testes padrao\n";
        cout << "0 - sair\n";
        cout << "opcao: ";

        string opcao;
        if (!getline(cin, opcao)) break;

        if (opcao == "1") {
            pda = criaPDApadrao();
            cout << "PDA padrao carregado.\n";
        } else if (opcao == "2") {
            pda = criaPDApersonalizado();
            cout << "PDA personalizado criado.\n";
        } else if (opcao == "3") {
            testaPalavra(pda);
        } else if (opcao == "4") {
            rodaTestes(pda);
        } else if (opcao == "0") {
            break;
        } else {
            cout << "opcao invalida\n";
        }
    }

    return 0;
}
